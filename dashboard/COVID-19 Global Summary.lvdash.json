                {
                  "value": "dev_catalog"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "320a37f7",
      "displayName": "kpi_deaths",
      "queryLines": [
        "SELECT SUM(final_new_deaths) as total_deaths\r\n",
        "FROM IDENTIFIER(:catalog || '.golden.covid_summary_by_country')"
      ],
      "parameters": [
        {
          "displayName": "catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
