                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "8b004b27",
      "displayName": "kpi_cfr",
      "queryLines": [
        "SELECT AVG(case_fatality_rate) as avg_cfr\r\n",
        "FROM IDENTIFIER(:catalog || '.golden.covid_summary_by_country')\r\n",
        "WHERE case_fatality_rate IS NOT NULL"
      ],
      "parameters": [
        {
          "displayName": "catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "dev_catalog"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "top10_cases_per_million",
      "displayName": "top10_cases_per_million",
      "queryLines": [
        "SELECT\n",
        "  country_norm,\n",
        "  cases_per_million\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.golden.covid_summary_by_country')\n",
        "WHERE\n",
        "  year_month\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year_month)\n",
        "      FROM\n",
        "        IDENTIFIER(:catalog || '.golden.covid_summary_by_country')\n",
        "      WHERE\n",
        "        cases_per_million IS NOT NULL\n",
        "        AND cases_per_million > 0\n",
        "        AND country_norm IS NOT NULL\n",
        "    )\n",
        "  AND cases_per_million IS NOT NULL\n",
        "  AND country_norm IS NOT NULL\n",
        "ORDER BY\n",
        "  cases_per_million DESC\n",
        "LIMIT 10"
      ],
      "parameters": [
        {
          "displayName": "catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "dev_catalog"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "c66179f9",
      "displayName": "map_deaths",
      "queryLines": [
        "SELECT INITCAP(LOWER(country_norm)) as country, deaths_per_million\r\n",
        "FROM IDENTIFIER(:catalog || '.golden.covid_summary_by_country')\r\n",
        "WHERE year_month = (\r\n",
        "  SELECT MAX(year_month) \r\n",
        "  FROM IDENTIFIER(:catalog || '.golden.covid_summary_by_country')\r\n",
        "  WHERE year_month LIKE '2024%' AND deaths_per_million IS NOT NULL\r\n",
        ")\r\n",
        "AND deaths_per_million IS NOT NULL"
      ],
      "parameters": [
        {
          "displayName": "catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "dev_catalog"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "top10_deaths_per_million",
      "displayName": "top10_deaths_per_million",
      "queryLines": [
        "SELECT\n",
        "  INITCAP(LOWER(country_norm)) as country,\n",
        "  deaths_per_million\n",
        "FROM\n",
        "  IDENTIFIER(:catalog || '.golden.covid_summary_by_country')\n",
        "WHERE\n",
        "  year_month\n",
        "    = (\n",
        "      SELECT\n",
        "        MAX(year_month)\n",
        "      FROM\n",
        "        IDENTIFIER(:catalog || '.golden.covid_summary_by_country')\n",
        "      WHERE\n",
        "        year_month LIKE '2024%'\n",
        "        AND deaths_per_million IS NOT NULL\n",
        "    )\n",
        "  AND deaths_per_million IS NOT NULL\n",
        "ORDER BY\n",
        "  deaths_per_million DESC\n",
        "LIMIT 10"
      ],
      "parameters": [
        {
          "displayName": "catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "dev_catalog"
                }
              ]
            }
          }
        }
      ]
    }
