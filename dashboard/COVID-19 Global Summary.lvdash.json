      "displayName": "kpi_cases",
      "queryLines": [
        "SELECT SUM(final_new_cases) as total_cases\r\n",
        "FROM IDENTIFIER(:catalog || '.golden.covid_summary_by_country')"
      ],
      "parameters": [
        {
          "displayName": "catalog",
          "keyword": "catalog",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
